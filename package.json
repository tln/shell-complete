{
  "name": "shell-complete",
  "version": "0.2.0",
  "description": "Dynamic shell completion engine for CLIs — Cobra-style __complete protocol for bash, zsh, and fish",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/stubs.js",
    "dist/stubs.d.ts",
    "dist/stubs.d.ts.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "tsc && node dist/test.js",
    "test:completion": "tsc && node dist/test-completion.js",
    "test:all": "tsc && node dist/test.js && node dist/test-completion.js"
  },
  "keywords": [
    "shell",
    "completion",
    "autocomplete",
    "tab-completion",
    "bash",
    "zsh",
    "fish",
    "cli",
    "cobra"
  ],
  "license": "MIT",
  "author": "tony@lownds.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tln/shell-complete.git"
  },
  "homepage": "https://github.com/tln/shell-complete#readme",
  "bugs": {
    "url": "https://github.com/tln/shell-complete/issues"
  },
  "engines": {
    "node": ">= 12"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "node-pty": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
